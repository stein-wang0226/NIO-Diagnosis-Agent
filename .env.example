# ============================================
# NIO Diagnosis Agent - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入你的 API Key

# ---- 方式1: OpenAI 兼容 API (推荐，支持任意 OpenAI 兼容端点) ----
# 适用于：阿里内部路由、vLLM、Ollama、Together AI、硅基流动等
OPENAI_API_KEY=sk-your_key_here
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_MODEL=deepseek-v3.2-thinking

# ---- 方式2: DeepSeek 官方 API ----
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ---- 方式3: 通义千问 API ----
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ---- Embedding 供应商 (可选覆盖) ----
# 如果 OpenAI 兼容端点不支持 embedding，设为 huggingface 使用本地模型
# 可选值: openai / tongyi / huggingface
# EMBEDDING_PROVIDER=huggingface

# ---- 可选：LangSmith 追踪 ----
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=nio-diagnosis-agent
# ============================================
# NIO Diagnosis Agent - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入你的 API Key

# ---- LLM 供应商 (二选一) ----
# DeepSeek API (推荐，性价比高)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 通义千问 API (备选)
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ---- 可选：LangSmith 追踪 ----
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=nio-diagnosis-agent
